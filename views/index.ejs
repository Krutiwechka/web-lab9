<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Чат с реакциями</title>
    <style>
        body { font-family: sans-serif; margin: 20px; display: flex; justify-content: center; align-items: center; height: 100vh; }
        
        /* Блок входа */
        .login-box { text-align: center; border: 1px solid #ccc; padding: 20px; border-radius: 5px; width: 300px; }
        input, button { padding: 10px; margin: 10px 0; width: 100%; box-sizing: border-box; }
        
        /* Блок чата (изначально скрыт) */
        #chat-wrap { display: none; width: 600px; margin: 0 auto; }
        #messages { border: 1px solid #ccc; height: 300px; overflow-y: scroll; padding: 10px; margin-bottom: 10px; list-style: none; }
        .msg-item { margin-bottom: 15px; padding: 5px; border-bottom: 1px dashed #eee; }
        .system-item { margin-bottom: 15px; padding: 5px; color: #888; font-style: italic; text-align: center; list-style: none; }
        .reactions { margin-top: 5px; }
        .react-btn { cursor: pointer; background: none; border: none; font-size: 16px; margin-right: 5px; }
        .count { font-size: 12px; color: #666; }
        #form { display: flex; }
        #input { flex-grow: 1; padding: 10px; }
        #form button { padding: 10px; width: auto; margin: 0; }
    </style>
</head>
<body>

    <!-- ФОРМА ВХОДА -->
    <div id="login-area" class="login-box">
        <h2>Войти в чат</h2>
        <form id="login-form">
            <input type="text" id="username-input" placeholder="Ваше имя" required>
            <button type="submit">Войти</button>
        </form>
    </div>

    <!-- ИНТЕРФЕЙС ЧАТА -->
    <div id="chat-wrap">
        <h3 id="chat-title"></h3>
        <ul id="messages"></ul>
        <form id="form">
            <input id="input" autocomplete="off" placeholder="Сообщение..." required />
            <button>Отправить</button>
        </form>
    </div>

    <script src="https://cdn.socket.io/4.7.5/socket.io.min.js"></script>
    <script>
        let socket;
        let username;

        const loginForm = document.getElementById('login-form');
        const usernameInput = document.getElementById('username-input');
        const loginArea = document.getElementById('login-area');
        const chatWrap = document.getElementById('chat-wrap');
        const chatTitle = document.getElementById('chat-title');
        
        const form = document.getElementById('form');
        const input = document.getElementById('input');
        const messages = document.getElementById('messages');
        const myReactions = {};

        // Обработка входа
        loginForm.addEventListener('submit', (e) => {
            e.preventDefault(); // Блокируем перезагрузку страницы и изменение URL
            username = usernameInput.value.trim();

            if (username) {
                // Скрываем форму входа, показываем чат
                document.body.style.alignItems = 'flex-start';
                loginArea.style.display = 'none';
                chatWrap.style.display = 'block';
                chatTitle.innerText = `Вы зашли как: ${username}`;

                // Подключаем сокет ТОЛЬКО после ввода имени
                initSocket();
            }
        });

        function initSocket() {
            socket = io({ transports: ['websocket'] });

            // Говорим серверу, как нас зовут (для уведомления)
            socket.emit('user joined', username);

            form.addEventListener('submit', (e) => {
                e.preventDefault();
                if (input.value) {
                    socket.emit('chat message', { username: username, text: input.value });
                    input.value = '';
                }
            });

            socket.on('chat message', (msg) => {
                const item = document.createElement('li');
                item.className = 'msg-item';
                item.id = msg.id;
                item.innerHTML = `
                    <strong>${msg.username}:</strong> <span>${msg.text}</span>
                    <div class="reactions">
                        <button class="react-btn" onclick="sendReaction('${msg.id}', '👍')">👍 <span class="count">0</span></button>
                        <button class="react-btn" onclick="sendReaction('${msg.id}', '❤️')">❤️ <span class="count">0</span></button>
                        <button class="react-btn" onclick="sendReaction('${msg.id}', '😂')">😂 <span class="count">0</span></button>
                    </div>
                `;
                messages.appendChild(item);
                messages.scrollTop = messages.scrollHeight;
            });

            socket.on('system notification', (text) => {
                const item = document.createElement('li');
                item.className = 'system-item';
                item.innerText = text;
                messages.appendChild(item);
                messages.scrollTop = messages.scrollHeight;
            });

            socket.on('message reaction', (data) => {
                const msgElement = document.getElementById(data.msgId);
                if (msgElement) {
                    const buttons = msgElement.querySelectorAll('.react-btn');
                    buttons.forEach(btn => {
                        if (btn.innerText.includes(data.emoji)) {
                            const countSpan = btn.querySelector('.count');
                            countSpan.innerText = parseInt(countSpan.innerText) + 1;
                        }
                    });
                }
            });
        }

        function sendReaction(msgId, emoji) {
            const reactionKey = msgId + '_' + emoji;
            if (myReactions[reactionKey]) return;
            myReactions[reactionKey] = true;
            socket.emit('message reaction', { msgId, emoji });
        }
    </script>
</body>
</html>
