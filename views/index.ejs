<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Чат с реакциями</title>
    <style>
        body { font-family: sans-serif; margin: 0; display: flex; justify-content: center; align-items: center; height: 100vh; background-color: #f9f9f9; }
        
        .login-box { text-align: center; border: 1px solid #ccc; padding: 20px; border-radius: 5px; width: 300px; background: white; }
        .login-box input, .login-box button { padding: 10px; margin: 10px 0; width: 100%; box-sizing: border-box; }
        
        #chat-wrap { display: none; width: 600px; background: white; border: 1px solid #ccc; padding: 20px; border-radius: 5px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        #messages { border: 1px solid #eee; height: 300px; overflow-y: scroll; padding: 10px; margin-bottom: 10px; list-style: none; }
        
        .chat-header { display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #f5f5f5; margin-bottom: 15px; padding-bottom: 5px; }
        .chat-header h3 { margin: 0; }
        .online-status { font-size: 14px; color: #2ecc71; font-weight: bold; }
        
        .msg-item { margin-bottom: 15px; padding: 5px; border-bottom: 1px dashed #eee; text-align: left; }
        .system-item { margin-bottom: 15px; padding: 5px; color: #888; font-style: italic; text-align: center; list-style: none; }
        
        .reactions { margin-top: 5px; display: flex; flex-direction: row; justify-content: flex-start; align-items: center; }
        .react-btn { cursor: pointer; background: none; border: none; font-size: 16px; margin-right: 10px; padding: 2px 5px; display: inline-block; width: auto; }
        .count { font-size: 12px; color: #666; }
        
        #form { display: flex; }
        #input { flex-grow: 1; padding: 10px; }
        #form button { padding: 10px; width: auto; margin: 0; }
    </style>
</head>
<body>

    <div id="login-area" class="login-box">
        <h2>Войти в чат</h2>
        <form id="login-form">
            <input type="text" id="username-input" placeholder="Ваше имя" required>
            <button type="submit">Войти</button>
        </form>
    </div>

    <div id="chat-wrap">
        <div class="chat-header">
            <h3 id="chat-title"></h3>
            <div class="online-status">В сети: <span id="online-counter">0</span></div>
        </div>
        
        <ul id="messages"></ul>
        
        <form id="form">
            <input id="input" autocomplete="off" placeholder="Сообщение..." required />
            <button>Отправить</button>
        </form>
    </div>

    <script src="https://cdn.socket.io/4.7.5/socket.io.min.js"></script>
    <script>
        let socket;
        let username;

        const loginForm = document.getElementById('login-form');
        const usernameInput = document.getElementById('username-input');
        const loginArea = document.getElementById('login-area');
        const chatWrap = document.getElementById('chat-wrap');
        const chatTitle = document.getElementById('chat-title');
        const onlineCounter = document.getElementById('online-counter');
        
        const form = document.getElementById('form');
        const input = document.getElementById('input');
        const messages = document.getElementById('messages');
        const myReactions = {};

        loginForm.addEventListener('submit', (e) => {
            e.preventDefault(); 
            username = usernameInput.value.trim();

            if (username) {
                loginArea.style.display = 'none';
                chatWrap.style.display = 'block';
                chatTitle.innerText = `Вы зашли как: ${username}`;
                initSocket();
            }
        });

        function renderMessage(msg) {
            const item = document.createElement('li');
            item.className = 'msg-item';
            item.id = msg.id;
            
            const thumbsUp = msg.reactions && msg.reactions['👍'] ? msg.reactions['👍'] : 0;
            const heart = msg.reactions && msg.reactions['❤️'] ? msg.reactions['❤️'] : 0;
            const laugh = msg.reactions && msg.reactions['😂'] ? msg.reactions['😂'] : 0;

            item.innerHTML = `
                <strong>${msg.username}:</strong> <span>${msg.text}</span>
                <div class="reactions">
                    <button class="react-btn" onclick="sendReaction('${msg.id}', '👍')">👍 <span class="count">${thumbsUp}</span></button>
                    <button class="react-btn" onclick="sendReaction('${msg.id}', '❤️')">❤️ <span class="count">${heart}</span></button>
                    <button class="react-btn" onclick="sendReaction('${msg.id}', '😂')">😂 <span class="count">${laugh}</span></button>
                </div>
            `;
            messages.appendChild(item);
        }

        function initSocket() {
            socket = io({ transports: ['websocket'] });

            socket.emit('user joined', username);

            form.addEventListener('submit', (e) => {
                e.preventDefault();
                if (input.value) {
                    socket.emit('chat message', { username: username, text: input.value });
                    input.value = '';
                }
            });

            socket.on('online count', (count) => {
                onlineCounter.innerText = count;
            });

            socket.on('chat history', (history) => {
                messages.innerHTML = '';
                history.forEach(msg => renderMessage(msg));
                messages.scrollTop = messages.scrollHeight;
            });

            socket.on('chat message', (msg) => {
                renderMessage(msg);
                messages.scrollTop = messages.scrollHeight;
            });

            socket.on('system notification', (text) => {
                const item = document.createElement('li');
                item.className = 'system-item';
                item.innerText = text;
                messages.appendChild(item);
                messages.scrollTop = messages.scrollHeight;
            });

            socket.on('message reaction', (data) => {
                const msgElement = document.getElementById(data.msgId);
                if (msgElement) {
                    const buttons = msgElement.querySelectorAll('.react-btn');
                    buttons.forEach(btn => {
                        if (btn.innerText.includes(data.emoji)) {
                            const countSpan = btn.querySelector('.count');
                            countSpan.innerText = parseInt(countSpan.innerText) + 1;
                        }
                    });
                }
            });
        }

        function sendReaction(msgId, emoji) {
            const reactionKey = msgId + '_' + emoji;
            if (myReactions[reactionKey]) return;
            myReactions[reactionKey] = true;
            socket.emit('message reaction', { msgId, emoji });
        }
    </script>
</body>
</html>
